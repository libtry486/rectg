---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { absoluteUrl, buildDirectoryData, categoryPath, itemPath, SITE_URL } from '../utils/data';

const { categories, validSections, featuredItems, totalItems, typeStats } = buildDirectoryData();
const sectionSummaries = validSections.map((group) => ({
  id: group.meta.id,
  icon: group.meta.icon,
  name: group.meta.name,
  fullName: group.meta.fullName,
  count: group.items.length,
}));
const categoryCountById = new Map(sectionSummaries.map((section) => [section.id, section.count]));
const initialSection = {
  id: 'featured',
  icon: '•',
  name: '目录摘选',
  fullName: '目录摘选',
  items: featuredItems,
};
const summaryStats = [
  { name: '总收录', count: totalItems },
  { name: '分类', count: validSections.length },
  ...typeStats,
];
const directoryPayload = JSON.stringify({
  sections: [
    initialSection,
    ...validSections.map((group) => ({
      id: group.meta.id,
      icon: group.meta.icon,
      name: group.meta.name,
      fullName: group.meta.fullName,
      keywords: group.meta.keywords || '',
      items: group.items,
    })),
  ],
}).replace(/</g, '\\u003c');

const pageDescription = `收录 ${totalItems} 个 Telegram 中文频道、群组和机器人，按主题整理公开资源，支持分类浏览、关键词搜索和详情查看。`;
const homeJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE_URL}/#website`,
    name: 'rectg',
    url: `${SITE_URL}/`,
    inLanguage: 'zh-CN',
    description: pageDescription,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: 'rectg',
    url: `${SITE_URL}/`,
    logo: `${SITE_URL}/og-image.png`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${SITE_URL}/#collection`,
    url: `${SITE_URL}/`,
    name: 'rectg Telegram 中文资源索引',
    description: pageDescription,
    inLanguage: 'zh-CN',
    isPartOf: { '@id': `${SITE_URL}/#website` },
    about: {
      '@type': 'Thing',
      name: 'Telegram 中文频道和群组',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    '@id': `${SITE_URL}/#featured-items`,
    name: 'rectg 目录摘选资源',
    numberOfItems: featuredItems.length,
    itemListElement: featuredItems.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: absoluteUrl(itemPath(item.id)),
      name: item.title,
    })),
  },
];
---

<Layout description={pageDescription} jsonLd={homeJsonLd}>
  <div id="app">
    <!-- 侧边栏 -->
    <aside id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <div class="logo-mark" aria-hidden="true">r</div>
          <div>
            <div class="sidebar-title">rectg</div>
            <div class="sidebar-subtitle">中文 TG 目录</div>
          </div>
        </div>
        <button id="close-sidebar-btn" aria-label="关闭侧边栏">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <nav id="category-nav">
        <div class="nav-section-label">目录</div>
        <a class="nav-item active" data-id="featured" href="/">
            <span class="nav-icon">•</span>
            <span>目录摘选</span>
        </a>
        {categories.map(cat => (
          <a class="nav-item" data-id={cat.id} href={categoryPath(cat.id)}>
              <span class="nav-icon">{cat.icon}</span>
              <span>{cat.name}</span>
              <span class="nav-count">{categoryCountById.get(cat.id) || 0}</span>
          </a>
        ))}
      </nav>
      <div class="sidebar-footer">
        <div class="sidebar-stats" aria-label="收录统计">
          {summaryStats.map(stat => (
            <div class="sidebar-stat">
              <span>{stat.name}</span>
              <strong>{stat.count}</strong>
            </div>
          ))}
        </div>
        <a href="https://github.com/jackvale/rectg/issues/new?template=channel_submission.md" target="_blank" rel="noopener" class="submit-btn" title="提交新的频道或群组">
          提交收录
        </a>
      </div>
    </aside>

    <!-- 移动端侧边栏遮罩 -->
    <div id="sidebar-overlay"></div>

    <!-- 主内容区 -->
    <main class="home-main">
      <header>
        <div class="header-left">
          <button id="menu-btn" aria-label="菜单">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
          <a class="topbar-brand" href="/" aria-label="rectg 首页">rectg</a>
        </div>

        <div class="header-search">
          <div class="search-box">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="search-input" placeholder="搜索频道、群组、关键词或 t.me 地址" autocomplete="off" />
            <button id="clear-search-btn" class="clear-search-btn" type="button" aria-label="清空搜索">
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>

        <div class="header-right">
          <a class="topbar-link" href="https://github.com/jackvale/rectg" target="_blank" rel="noopener">源码</a>
          <a class="topbar-link" href="https://github.com/jackvale/rectg/issues/new?template=channel_submission.md" target="_blank" rel="noopener">收录</a>
          <button id="theme-toggle" aria-label="切换主题">
            <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </button>
        </div>
      </header>

      <!-- Reading Progress Bar -->
      <div id="progress-container">
        <div id="progress-bar"></div>
      </div>

      <div class="mobile-category-strip" aria-label="分类">
        <a class="mobile-category-item active" href="/" data-id="featured">
          <span>摘选</span>
          <strong>{featuredItems.length}</strong>
        </a>
        {sectionSummaries.map(section => (
          <a class="mobile-category-item" href={categoryPath(section.id)} data-id={section.id}>
            <span>{section.name}</span>
            <strong>{section.count}</strong>
          </a>
        ))}
      </div>

      <div id="content-container">
        <section class="category-section" id="active-section" data-current-id={initialSection.id}>
          <div class="section-heading">
            <div>
              <h1 class="category-title">
                <span id="active-section-title">{initialSection.fullName}</span>
                <span id="active-section-meta" class="category-title-meta">({initialSection.items.length})</span>
              </h1>
              <p id="active-section-desc" class="category-description">从全站目录选出的一组入口，按主题分布和人数参考整理。</p>
            </div>
            <div id="result-status" class="result-status" hidden>
              <span id="result-status-text">已显示目录摘选</span>
              <button id="result-clear-btn" type="button">清空</button>
            </div>
          </div>
          <div class="grid" id="active-grid">
            {initialSection.items.map(item => (
              <Card
                id={item.id}
                title={item.title}
                desc={item.desc}
                url={item.url}
                typeName={item.typeName}
                countStr={item.countStr}
                category={item.categoryName || item.categoryFullName || '目录摘选'}
              />
            ))}
          </div>
        </section>

        <section class="aeo-panel directory-note" aria-labelledby="about-rectg-title">
          <div class="directory-note-main">
            <h2 id="about-rectg-title">关于本站</h2>
            <p>rectg 是一个中文 Telegram 公开资源目录，整理频道、群组和机器人入口。目录按主题归类，保留人数、简介、详情页和 Telegram 链接，适合用来查找同类资源和做加入前的初步核对。</p>
          </div>
          <div class="directory-note-meta" aria-label="目录说明">
            <span>{totalItems} 个资源</span>
            <span>{validSections.length} 个分类</span>
            <span>公开信息整理</span>
          </div>

          <div class="faq-list compact-faq" aria-label="常见问题">
            <details>
              <summary>rectg 收录哪些 Telegram 资源？</summary>
              <p>主要收录中文 Telegram 频道、群组和机器人，覆盖新闻、科技、开发、影视、学习、工具、地区社群等主题。</p>
            </details>
            <details>
              <summary>怎样查找频道或群组？</summary>
              <p>在首页搜索框输入频道名、群组名、主题关键词或 t.me 地址，结果会按标题、分类、简介和链接相关性排序。</p>
            </details>
            <details>
              <summary>怎样提交新的资源？</summary>
              <p>通过项目收录入口提供名称、链接、类型、简介和主题，后续会根据公开信息和收录原则处理。</p>
            </details>
            <details>
              <summary>订阅数或人数代表什么？</summary>
              <p>订阅数或人数仅作为浏览参考，可能随 Telegram 实际数据变化而变化，不代表站点背书或质量保证。</p>
            </details>
          </div>
        </section>

        <div id="empty-state" class="empty-state" style="display: none;">
            <h3>没有匹配结果</h3>
            <p>换一个关键词，或回到目录摘选继续浏览。</p>
            <div class="empty-actions">
              <button type="button" data-empty-action="featured">查看摘选</button>
              <button type="button" data-empty-action="clear">清空搜索</button>
            </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Back to Top Button -->
  <button id="back-to-top" class="back-to-top" aria-label="返回顶部">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="19" x2="12" y2="5"></line>
      <polyline points="5 12 12 5 19 12"></polyline>
    </svg>
  </button>
  
  <div id="toast" class="toast">已复制链接</div>

  <footer class="site-footer">
    <div class="footer-content">
      <p><strong>站点说明</strong>：本网站只整理公开 Telegram 资源入口，不运营或代表被收录资源。访问和加入前请自行核对内容风险，并遵守所在地法律法规。</p>
      <p class="footer-copyright">© 2026 rectg – Telegram 中文目录</p>
    </div>
  </footer>

  <script id="directory-data" type="application/json" set:html={directoryPayload}></script>
  <script src="../scripts/main.js"></script>
</Layout>
